#!/bin/bash

set -xo pipefail
set -eE

WORKFLOW="<%= context.workflow %>"
RUN_DIR=$(echo "<%= context.run_name %>" | sed "s#[^A-Za-z0-9]#_#g")

ENV_FILE=".env"
if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
fi

module purge
module load java/21 nextflow/24

export APPTAINER_CACHEDIR="${APPTAINER_CACHEDIR:-/srv/scratch/${USER}/apptainer_cache/}"
export NXF_APPTAINER_CACHEDIR="${NXF_APPTAINER_CACHEDIR:-/srv/scratch/${USER}/apptainer_cache/}"
export NXF_APPTAINER_LIBRARYDIR="${NXF_APPTAINER_LIBRARYDIR:-/srv/scratch/sbf/apptainer_cache/}"

if [ "$WORKFLOW" = "bindflow" ]; then
    BASEDIR=/srv/scratch/sbf-pipelines/bindflow/
    JOBCONFIGDIR=${BASEDIR}/advanced/
    FILTERCONFIGDIR=${BASEDIR}/filters/

    export NXF_WORK="/srv/scratch/${USER}/.bindflow/work"
    mkdir -p "${NXF_WORK}"

    BASE_OUT_DIR="${BASE_OUT_DIR:-${PROTEINDESIGN_BIND_OUT_DIR:-/srv/scratch/${USER}/bindflow_output}}"
    OUT_DIR="${BASE_OUT_DIR}/${RUN_DIR}"
    mkdir -p "${OUT_DIR}"

    run_name="<%= context.run_name %>"
    target="<%= context.target %>"
    chain="<%= context.target_chain %>"
    hotspots="<%= context.hotspots %>"
    min_length="<%= context.minlen %>"
    max_length="<%= context.maxlen %>"
    ndesigns="<%= context.ndesigns %>"
    jobconfig="<%= context.jobconfig %>"
    filterconfig="<%= context.filterconfig %>"

    echo "id,binder_name,starting_pdb,chains,target_hotspot_residues,min_length,max_length,number_of_final_designs,settings_advanced,settings_filters" > samplesheet.csv
    printf '"%s","%s","%s","%s","%s",%s,%s,%s,"%s","%s"\n' \
        "${run_name}" \
        "${run_name}" \
        "${target}" \
        "${chain}" \
        "${hotspots}" \
        "${min_length}" \
        "${max_length}" \
        "${ndesigns}" \
        "${JOBCONFIGDIR}/${jobconfig}" \
        "${FILTERCONFIGDIR}/${filterconfig}" >> samplesheet.csv

    nextflow run Australian-Structural-Biology-Computing/bindflow \
        --input samplesheet.csv \
        --outdir ${OUT_DIR} \
        -c ${BASEDIR}/kod-bindflow.config \
        -profile apptainer \
        -r 93e8ac776fae1c76d283dcc64f4e4571cae7a091 \
        -latest
else
    BASE_DIR=/srv/scratch/sbf-pipelines/pdj-denovo/
    MODEL_DIR=${BASE_DIR}/models/

    export NXF_WORK="/srv/scratch/${USER}/.proteindj/work"
    mkdir -p "${NXF_WORK}"

    BASE_OUT_DIR="${BASE_OUT_DIR:-${PROTEINDESIGN_PDJ_OUT_DIR:-/srv/scratch/${USER}/proteindj_output}}"
    OUT_DIR="${BASE_OUT_DIR}/${RUN_DIR}"
    mkdir -p "${OUT_DIR}"

    run_name="<%= context.run_name %>"
    target="<%= context.target %>"
    chain="<%= context.target_chain %>"
    seq_method="<%= context.pdj_seq_method %>"
    pred_method="<%= context.pdj_pred_method %>"
    rfd_contigs="<%= context.pdj_rfd_contigs %>"
    hotspots_raw="<%= context.hotspots %>"
    hotspots_clean=$(echo "${hotspots_raw}" | tr -d '[:space:]' | sed -E 's/,+/,/g; s/^,//; s/,$//')

    # ProteinDJ expects chain-prefixed hotspots (e.g. A231). We accept numeric
    # input and defensively avoid double-prefixing if a chain was provided.
    hotspots=""
    IFS=',' read -r -a hotspot_items <<< "${hotspots_clean}"
    for item in "${hotspot_items[@]}"; do
        [ -z "${item}" ] && continue

        if [[ "${item}" =~ ^[0-9]+$ ]]; then
            formatted="${chain}${item}"
        elif [[ "${item}" =~ ^[A-Za-z][0-9]+$ ]]; then
            formatted="${item}"
        else
            formatted="${item}"
        fi

        if [ -n "${hotspots}" ]; then
            hotspots="${hotspots},${formatted}"
        else
            hotspots="${formatted}"
        fi
    done
    min_length="<%= context.minlen %>"
    max_length="<%= context.maxlen %>"
    ndesigns="<%= context.ndesigns %>"
    nseqs="<%= context.seqs_per_design %>"
    design_length="${min_length}-${max_length}"

    if [ -z "${rfd_contigs}" ]; then
        residue_numbers=$(awk -v chain_id="${chain}" '
            substr($0, 1, 4) == "ATOM" && substr($0, 22, 1) == chain_id {
                res = substr($0, 23, 4)
                gsub(/ /, "", res)
                if (res ~ /^-?[0-9]+$/) print res
            }
        ' "${target}" | sort -n | uniq)

        first_res=$(echo "${residue_numbers}" | head -n1)
        last_res=$(echo "${residue_numbers}" | tail -n1)

        if [ -z "${first_res}" ] || [ -z "${last_res}" ]; then
            echo "ERROR: Could not infer residues for chain '${chain}' from input PDB '${target}'."
            echo "Please provide RFdiffusion contigs explicitly."
            exit 1
        fi

        rfd_contigs="[${chain}${first_res}-${last_res}/0 ${design_length}]"
        echo "Auto-generated rfd_contigs: ${rfd_contigs}"
    fi

    af2_max_pae_interaction="<%= context.af2_max_pae_interaction %>"
    af2_min_plddt_overall="<%= context.af2_min_plddt_overall %>"
    af2_max_rmsd_binder_bndaln="<%= context.af2_max_rmsd_binder_bndaln %>"
    af2_max_rmsd_binder_tgtaln="<%= context.af2_max_rmsd_binder_tgtaln %>"

    boltz_max_rmsd_binder="<%= context.boltz_max_rmsd_binder %>"
    boltz_max_rmsd_target="<%= context.boltz_max_rmsd_target %>"
    boltz_max_rmsd_overall="<%= context.boltz_max_rmsd_overall %>"
    boltz_min_ptm_interface="<%= context.boltz_min_ptm_interface %>"

    mpnn_relax_max_cycles="<%= context.mpnn_relax_max_cycles %>"
    uncropped_target_pdb="<%= context.uncropped_target_pdb %>"
    boltz_use_templates="<%= context.boltz_use_templates %>"
    boltz_input_msa="<%= context.boltz_input_msa %>"
    fold_min_ss="<%= context.fold_min_ss %>"
    seq_min_ext_coef="<%= context.seq_min_ext_coef %>"
    max_designs="<%= context.max_designs %>"
    max_seqs_per_fold="<%= context.max_seqs_per_fold %>"

    pdj_args=(
        # Schema-style names (PapenfussLab/proteindj)
        --design_mode 'binder_denovo'
        --num_designs "${ndesigns}"
        --input_pdb "${target}"
        --hotspot_residues "${hotspots}"
        # Legacy names (older tlitfin/PapenfussLab revisions)
        --rfd_num_designs "${ndesigns}"
        --rfd_mode 'binder_denovo'
        --rfd_input_pdb "${target}"
        --rfd_hotspots "[${hotspots}]"
        --design_length "${design_length}"
        --seqs_per_design "${nseqs}"
        --seq_method "${seq_method}"
        --pred_method "${pred_method}"
        --gpus 20
        --out_dir "${OUT_DIR}"
        --af2_models "${MODEL_DIR}/af2/"
        --rfd_models "${MODEL_DIR}/rfd/"
    )

    pdj_args+=(--rfd_contigs "${rfd_contigs}")

    if [ "${pred_method}" = "af2" ]; then
        [ -n "${af2_max_pae_interaction}" ] && pdj_args+=(--af2_max_pae_interaction "${af2_max_pae_interaction}")
        [ -n "${af2_min_plddt_overall}" ] && pdj_args+=(--af2_min_plddt_overall "${af2_min_plddt_overall}")
        [ -n "${af2_max_rmsd_binder_bndaln}" ] && pdj_args+=(--af2_max_rmsd_binder_bndaln "${af2_max_rmsd_binder_bndaln}")
        [ -n "${af2_max_rmsd_binder_tgtaln}" ] && pdj_args+=(--af2_max_rmsd_binder_tgtaln "${af2_max_rmsd_binder_tgtaln}")
    elif [ "${pred_method}" = "boltz" ]; then
        [ -n "${boltz_use_templates}" ] && pdj_args+=(--boltz_use_templates "${boltz_use_templates}")
        [ -n "${boltz_input_msa}" ] && pdj_args+=(--boltz_input_msa "${boltz_input_msa}")
        [ -n "${boltz_max_rmsd_binder}" ] && pdj_args+=(--boltz_max_rmsd_binder "${boltz_max_rmsd_binder}")
        [ -n "${boltz_max_rmsd_target}" ] && pdj_args+=(--boltz_max_rmsd_target "${boltz_max_rmsd_target}")
        [ -n "${boltz_max_rmsd_overall}" ] && pdj_args+=(--boltz_max_rmsd_overall "${boltz_max_rmsd_overall}")
        [ -n "${boltz_min_ptm_interface}" ] && pdj_args+=(--boltz_min_ptm_interface "${boltz_min_ptm_interface}")
    fi

    [ -n "${mpnn_relax_max_cycles}" ] && pdj_args+=(--mpnn_relax_max_cycles "${mpnn_relax_max_cycles}")
    [ -n "${uncropped_target_pdb}" ] && pdj_args+=(--uncropped_target_pdb "${uncropped_target_pdb}")
    [ -n "${fold_min_ss}" ] && pdj_args+=(--fold_min_ss "${fold_min_ss}")
    [ -n "${seq_min_ext_coef}" ] && pdj_args+=(--seq_min_ext_coef "${seq_min_ext_coef}")
    [ -n "${max_designs}" ] && pdj_args+=(--max_designs "${max_designs}")
    [ -n "${max_seqs_per_fold}" ] && pdj_args+=(--max_seqs_per_fold "${max_seqs_per_fold}")

    nextflow run tlitfin/proteindj \
        "${pdj_args[@]}" \
        -c ${BASE_DIR}/kod-pdj-denovo.config \
        -profile apptainer \
        -r main
fi
