<%
def file_url(base, path)
  encoded_path = path.to_s.split("/").reject(&:empty?).map { |segment| ERB::Util.url_encode(segment) }.join("/")
  "#{base}/#{encoded_path}"
end

def tail_text(path, max_bytes = 65536, max_lines = 120)
  return nil unless File.file?(path)

  File.open(path, "rb") do |file|
    size = file.size
    offset = [size - max_bytes, 0].max
    file.seek(offset)
    text = file.read.to_s

    if offset > 0
      newline_index = text.index("\n")
      text = newline_index ? text[(newline_index + 1)..] : text
    end

    lines = text.lines
    lines = lines.last(max_lines) if max_lines && max_lines > 0
    lines.join
  end
end

def sanitize_live_log(text)
  return nil if text.nil?

  ansi_pattern = /\e\[[0-9;?]*[ -\/]*[@-~]/
  lines = text.gsub(ansi_pattern, "").split("\n")
  cleaned = []
  index = 0

  while index < lines.length
    line = lines[index]

    if line.start_with?("WARN: cpus and memory directives are ignored when clusterOptions contains -l option")
      index += 1
      index += 1 while index < lines.length && lines[index].start_with?("tip:", "- ")
      next
    end

    if line.start_with?("WARN: [PBSPRO] queue status cannot be fetched")
      index += 1
      index += 1 while index < lines.length && !lines[index].strip.empty?
      index += 1 if index < lines.length && lines[index].strip.empty?
      next
    end

    cleaned << line
    index += 1
  end

  filtered = []
  previous_status_block = nil
  index = 0

  while index < cleaned.length
    line = cleaned[index]

    if line =~ /^(executor >|\[[^\]]*\])/
      block = []
      while index < cleaned.length && cleaned[index] =~ /^(executor >|\[[^\]]*\])/
        block << cleaned[index]
        index += 1
      end

      if block != previous_status_block
        filtered.concat(block)
        previous_status_block = block
      end

      next
    end

    filtered << line
    previous_status_block = nil unless line.strip.empty?
    index += 1
  end

  compact = []
  blank_streak = 0

  filtered.each do |line|
    if line.strip.empty?
      blank_streak += 1
      compact << "" if blank_streak == 1
    else
      blank_streak = 0
      compact << line
    end
  end

  compact.join("\n").strip
end

workflow_value = (defined?(workflow) && workflow && !workflow.to_s.empty?) ? workflow.to_s : "proteindj"
default_base_out_dir = if workflow_value == "bindflow"
  ENV.fetch("PROTEINDESIGN_BIND_OUT_DIR")
else
  ENV.fetch("PROTEINDESIGN_PDJ_OUT_DIR")
end
default_results_url_base = ENV.fetch("OOD_RESULTS_URL_BASE")
resolved_base_out_dir = (defined?(base_out_dir) && base_out_dir && !base_out_dir.to_s.empty?) ? base_out_dir.to_s : default_base_out_dir
resolved_results_url_base = (defined?(results_url_base) && results_url_base && !results_url_base.to_s.empty?) ? results_url_base.to_s : default_results_url_base

log_dir = (defined?(session_output_dir) && session_output_dir && !session_output_dir.to_s.empty?) ? session_output_dir.to_s : File.join(resolved_base_out_dir, run_dir.to_s)
log_path = File.join(log_dir, "live_log.log")
log_url = file_url(resolved_results_url_base, log_path)
log_text = sanitize_live_log(tail_text(log_path))
%>
<div class="ood-appkit markdown">
  <div class="ood-live-log-card">
    <div><b>Log</b>: <a target="_blank" rel="noopener" href="<%= log_url %>">live_log.log</a></div>
    <pre class="ood-live-log" data-log-path="<%= ERB::Util.html_escape(log_path) %>" style="margin-top: 0.75rem !important; min-height: 9rem !important; max-height: 12rem !important; overflow: auto !important; padding: 1rem !important; background: #0f172a !important; color: #f8fafc !important; border: 1px solid #334155 !important; border-radius: 0.5rem !important; white-space: pre-wrap !important; font: 0.9rem/1.45 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace !important;"><%= log_text && !log_text.empty? ? ERB::Util.html_escape(log_text) : "Waiting for log output..." %></pre>
  </div>
</div>
<script>
  (() => {
    const scriptEl = document.currentScript;
    const logEl = scriptEl ? scriptEl.previousElementSibling.querySelector(".ood-live-log") : null;
    if (!logEl) return;

    window.requestAnimationFrame(() => {
      logEl.scrollTop = logEl.scrollHeight;
    });
  })();
</script>
