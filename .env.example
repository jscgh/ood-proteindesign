# Copy this file to `template/.env` and adjust values for your site.

# Runtime settings
OOD_RESULTS_URL_BASE=/pun/sys/dashboard/files/fs
PROTEINDESIGN_NATIVE_DEFAULT=-A your_project;-l select=1:ncpus=2:mem=4gb;-l walltime=48:00:00

# Shared result and preview settings
PROTEINDESIGN_MOLSTAR_URL_TEMPLATE=/pun/sys/dashboard/files/fs/__PATH_SEGMENTS__

# BindFlow settings
PROTEINDESIGN_BIND_BASEDIR=/path/to/bindflow
PROTEINDESIGN_BIND_OUT_DIR=/path/to/output/bindflow_output
PROTEINDESIGN_BIND_WORK_DIR=/path/to/work/bindflow
PROTEINDESIGN_BIND_REPOSITORY=Australian-Structural-Biology-Computing/bindflow
PROTEINDESIGN_BIND_REVISION=93e8ac776fae1c76d283dcc64f4e4571cae7a091
PROTEINDESIGN_BIND_NEXTFLOW_CONFIG=/path/to/bindflow/nextflow.config

# ProteinDJ settings
PROTEINDESIGN_PDJ_BASEDIR=/path/to/proteindj
PROTEINDESIGN_PDJ_OUT_DIR=/path/to/output/proteindj_output
PROTEINDESIGN_PDJ_WORK_DIR=/path/to/work/proteindj
PROTEINDESIGN_PDJ_REPOSITORY=tlitfin/proteindj
PROTEINDESIGN_PDJ_REVISION=main
PROTEINDESIGN_PDJ_NEXTFLOW_CONFIG=/path/to/proteindj/nextflow.config

# Container caches
APPTAINER_CACHEDIR=/path/to/cache/apptainer
NXF_APPTAINER_CACHEDIR=/path/to/cache/apptainer
NXF_APPTAINER_LIBRARYDIR=/path/to/library/apptainer
