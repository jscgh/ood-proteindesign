form:
    - workflow
    - data_warning
    - run_name
    - target
    - target_preview
    - target_chain
    - hotspots
    - minlen
    - maxlen
    - ndesigns
    - seqs_per_design
    - pdj_seq_method
    - pdj_pred_method
    - pdj_show_advanced
    - mpnn_relax_max_cycles
    - uncropped_target_pdb
    - boltz_use_templates
    - boltz_input_msa
    - fold_min_ss
    - seq_min_ext_coef
    - max_designs
    - max_seqs_per_fold
    - af2_max_pae_interaction
    - af2_min_plddt_overall
    - af2_max_rmsd_binder_bndaln
    - af2_max_rmsd_binder_tgtaln
    - boltz_max_rmsd_binder
    - boltz_max_rmsd_target
    - boltz_max_rmsd_overall
    - boltz_min_ptm_interface
    - jobconfig
    - filterconfig
    - citation_request
    - katana_citation

cluster: "<%= ENV.fetch('OOD_CLUSTER') %>"

attributes:
    workflow:
        widget: "select"
        label: "Design Workflow"
        help: |
            Choose which backend pipeline to run for this submission.
        options:
            - ["ProteinDJ (RFdiffusion workflow)", "proteindj", data-hide-jobconfig: true, data-hide-filterconfig: true]
            - ["BindFlow (BindCraft workflow)", "bindflow", data-hide-seqs_per_design: true, data-hide-pdj_seq_method: true, data-hide-pdj_pred_method: true, data-hide-pdj_show_advanced: true, data-hide-mpnn_relax_max_cycles: true, data-hide-uncropped_target_pdb: true, data-hide-boltz_use_templates: true, data-hide-boltz_input_msa: true, data-hide-fold_min_ss: true, data-hide-seq_min_ext_coef: true, data-hide-max_designs: true, data-hide-max_seqs_per_fold: true, data-hide-af2_max_pae_interaction: true, data-hide-af2_min_plddt_overall: true, data-hide-af2_max_rmsd_binder_bndaln: true, data-hide-af2_max_rmsd_binder_tgtaln: true, data-hide-boltz_max_rmsd_binder: true, data-hide-boltz_max_rmsd_target: true, data-hide-boltz_max_rmsd_overall: true, data-hide-boltz_min_ptm_interface: true]

    data_warning:
        class: "d-none"
        help: |
            <div style="padding: 0.375rem 0.75rem; background-color: #E2BEBE; border: 2px solid #761313; border-radius: 0.25rem; color: #761313;">
                <span><b>Warning!</b> Please ensure your input data complies with your site's data handling rules. Many HPC clusters are <b>not</b> approved for sensitive or highly sensitive data.</span>
            </div>

    run_name:
        widget: "text_field"
        pattern: '^[A-Za-z0-9_\- ]+$'
        label: "Run Name"
        placeholder: "Job_name"
        required: true
        help: |
            Alphanumeric, space, "_" and "-" only.

    target:
        widget: "path_selector"
        label: "Target PDB"
        pattern: "*.pdb^"
        placeholder: "/path/to/my_project/target.pdb"
        required: true
        help: |
            Path to a PDB file containing the target structure.

    target_preview:
        class: "d-none"
        help: |
            <div id="ood-molstar-preview"
                 data-url-template="<%= ENV.fetch('PROTEINDESIGN_MOLSTAR_URL_TEMPLATE', '/pun/sys/dashboard/files/fs/__PATH_SEGMENTS__') %>">
                <button type="button" id="ood-molstar-load" class="btn btn-secondary btn-sm">
                    Preview Target
                </button>
                <div id="ood-molstar-status" style="margin-top: 0.5rem; color: #555;"></div>
                <div id="ood-molstar-container" style="height: 420px; margin-top: 0.75rem; border: 1px solid #d0d0d0; border-radius: 0.25rem; overflow: hidden;"></div>
            </div>

    target_chain:
        widget: "text_field"
        label: "Target Chain"
        placeholder: "A"
        pattern: "^[A-Za-z0-9]$"
        required: true
        help: |
            Single alphanumeric character.

    hotspots:
        widget: "text_field"
        label: "Target Hotspots"
        placeholder: "231,235,427,431"
        pattern: '^[0-9, ]+$'
        required: true
        help: |
            Comma-separated residue numbers (spaces allowed).

    minlen:
        widget: "number_field"
        label: "Minimum Length"
        value: 60
        min: 10
        max: 199
        required: true

    maxlen:
        widget: "number_field"
        label: "Maximum Length"
        value: 100
        min: 11
        max: 200
        required: true

    ndesigns:
        widget: "number_field"
        label: "Number of Designs"
        value: 100
        min: 1
        max: 1000
        required: true

    seqs_per_design:
        widget: "number_field"
        label: "Seqs per Backbone Design (ProteinDJ only)"
        value: 8
        min: 1
        max: 20

    pdj_seq_method:
        widget: "select"
        label: "Sequence Design Method (ProteinDJ only)"
        help: |
            ProteinMPNN is generally preferred for binder quality.
        options:
            - ["ProteinMPNN (+FastRelax path)", "mpnn"]
            - ["FAMPNN", "fampnn", data-hide-mpnn_relax_max_cycles: true]

    pdj_pred_method:
        widget: "select"
        label: "Structure Prediction Method (ProteinDJ only)"
        options:
            - ["Boltz-2", "boltz", data-hide-af2_max_pae_interaction: true, data-hide-af2_min_plddt_overall: true, data-hide-af2_max_rmsd_binder_bndaln: true, data-hide-af2_max_rmsd_binder_tgtaln: true]
            - ["AlphaFold2 Initial Guess", "af2", data-hide-boltz_use_templates: true, data-hide-boltz_input_msa: true, data-hide-boltz_max_rmsd_binder: true, data-hide-boltz_max_rmsd_target: true, data-hide-boltz_max_rmsd_overall: true, data-hide-boltz_min_ptm_interface: true]

    pdj_show_advanced:
        widget: "check_box"
        label: "Show Advanced ProteinDJ Options"
        checked_value: "yes"
        unchecked_value: "no"
        help: |
            Optional expert controls. Defaults are usually suitable.

    mpnn_relax_max_cycles:
        widget: "number_field"
        label: "FastRelax Cycles (ProteinMPNN path)"
        value: 1
        min: 0
        max: 10
        help: |
            Set > 0 to enable FastRelax cycles (better quality, slower runtime).

    uncropped_target_pdb:
        widget: "path_selector"
        label: "Uncropped Target PDB (optional)"
        pattern: "*.pdb^"
        placeholder: "/path/to/my_project/target_uncropped.pdb"

    boltz_use_templates:
        widget: "select"
        label: "Boltz Use Templates"
        options:
            - ["Yes", "true"]
            - ["No", "false"]

    boltz_input_msa:
        widget: "path_selector"
        label: "Boltz Input MSA (optional)"
        pattern: "*.a3m^"
        placeholder: "/path/to/my_project/target.a3m"

    fold_min_ss:
        widget: "number_field"
        label: "Min Secondary Structure Elements"
        min: 0
        max: 10
        value: 3

    seq_min_ext_coef:
        widget: "number_field"
        label: "Min Extinction Coefficient"
        value: 1000
        min: 0

    max_designs:
        widget: "number_field"
        label: "Max Final Designs to Keep"
        min: 1
        value: 100
        max: 1000

    max_seqs_per_fold:
        widget: "number_field"
        label: "Max Sequences per Fold"
        min: 1
        max: 10
        value: 4

    af2_max_pae_interaction:
        widget: "number_field"
        label: "AF2 max PAE interaction"
        value: 10
        min: 0

    af2_min_plddt_overall:
        widget: "number_field"
        label: "AF2 min pLDDT overall"
        value: 90
        min: 0
        max: 100

    af2_max_rmsd_binder_bndaln:
        widget: "number_field"
        label: "AF2 max binder RMSD (binder-aligned)"
        value: 1.5
        min: 0
        step: 0.1

    af2_max_rmsd_binder_tgtaln:
        widget: "number_field"
        label: "AF2 max binder RMSD (target-aligned)"
        value: 2
        min: 0
        step: 0.1

    boltz_max_rmsd_binder:
        widget: "number_field"
        label: "Boltz max binder RMSD"
        value: 1.5
        min: 0
        step: 0.1

    boltz_max_rmsd_target:
        widget: "number_field"
        label: "Boltz max target RMSD"
        value: 2
        min: 0
        step: 0.1

    boltz_max_rmsd_overall:
        widget: "number_field"
        label: "Boltz max overall RMSD"
        value: 2.5
        min: 0
        step: 0.1

    boltz_min_ptm_interface:
        widget: "number_field"
        label: "Boltz min pTM interface"
        value: 0.85
        min: 0
        max: 1
        step: 0.01

    jobconfig:
        widget: "select"
        label: "Job Configuration (BindFlow only)"
        options:
            - ["default_4stage_multimer.json", "default_4stage_multimer.json"]
            - ["betasheet_4stage_multimer.json", "betasheet_4stage_multimer.json"]
            - ["betasheet_4stage_multimer_flexible.json", "betasheet_4stage_multimer_flexible.json"]
            - ["betasheet_4stage_multimer_flexible_hardtarget.json", "betasheet_4stage_multimer_flexible_hardtarget.json"]
            - ["betasheet_4stage_multimer_hardtarget.json", "betasheet_4stage_multimer_hardtarget.json"]
            - ["betasheet_4stage_multimer_mpnn.json", "betasheet_4stage_multimer_mpnn.json"]
            - ["betasheet_4stage_multimer_mpnn_flexible.json", "betasheet_4stage_multimer_mpnn_flexible.json"]
            - ["betasheet_4stage_multimer_mpnn_flexible_hardtarget.json", "betasheet_4stage_multimer_mpnn_flexible_hardtarget.json"]
            - ["betasheet_4stage_multimer_mpnn_hardtarget.json", "betasheet_4stage_multimer_mpnn_hardtarget.json"]
            - ["default_4stage_multimer_mpnn.json", "default_4stage_multimer_mpnn.json"]
            - ["default_4stage_multimer_flexible.json", "default_4stage_multimer_flexible.json"]
            - ["default_4stage_multimer_flexible_hardtarget.json", "default_4stage_multimer_flexible_hardtarget.json"]
            - ["default_4stage_multimer_hardtarget.json", "default_4stage_multimer_hardtarget.json"]
            - ["default_4stage_multimer_mpnn_flexible.json", "default_4stage_multimer_mpnn_flexible.json"]
            - ["default_4stage_multimer_mpnn_flexible_hardtarget.json", "default_4stage_multimer_mpnn_flexible_hardtarget.json"]
            - ["default_4stage_multimer_mpnn_hardtarget.json", "default_4stage_multimer_mpnn_hardtarget.json"]
            - ["peptide_3stage_multimer.json", "peptide_3stage_multimer.json"]
            - ["peptide_3stage_multimer_flexible.json", "peptide_3stage_multimer_flexible.json"]
            - ["peptide_3stage_multimer_mpnn.json", "peptide_3stage_multimer_mpnn.json"]
            - ["peptide_3stage_multimer_mpnn_flexible.json", "peptide_3stage_multimer_mpnn_flexible.json"]

    filterconfig:
        widget: "select"
        label: "Filter Configuration (BindFlow only)"
        options:
            - ["default_filters.json", "default_filters.json"]
            - ["no_filters.json", "no_filters.json"]
            - ["peptide_filters.json", "peptide_filters.json"]
            - ["peptide_relaxed_filters.json", "peptide_relaxed_filters.json"]
            - ["relaxed_filters.json", "relaxed_filters.json"]

    citation_request:
        label: "Facility Citation"
        class: "d-none"
        help: |
            Please include the following acknowledgement in publications that use this resource:
            <br>
            <i>"The authors acknowledge use of facilities in the Structural Biology Facility within the Mark Wainwright Analytical Centre - UNSW"</i>
            <br>
            <b>DOI:</b> <a href="https://doi.org/10.26190/4KQF-M552">10.26190/4KQF-M552</a>

    katana_citation:
        label: "Katana HPC Citation"
        class: "d-none"
        help: |
            Please include the following acknowledgement in publications that use Katana:
            <br>
            <i>"This research includes computations using the computational cluster Katana supported by Research Technology Services at UNSW Sydney."</i>
            <br>
            <b>DOI:</b> <a href="https://doi.org/10.26190/669x-a286">10.26190/669X-A286</a>
