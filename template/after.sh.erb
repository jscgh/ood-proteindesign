ENV_FILE=".env"
if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
fi

RUN_DIR=$(echo "<%= context.run_name %>" | sed "s#[^A-Za-z0-9]#_#g")
WORKFLOW="<%= context.workflow %>"

if [ "$WORKFLOW" = "bindflow" ]; then
    BASE_OUT_DIR="${BASE_OUT_DIR:-${PROTEINDESIGN_BIND_OUT_DIR:-/srv/scratch/${USER}/bindflow_output}}"
else
    BASE_OUT_DIR="${BASE_OUT_DIR:-${PROTEINDESIGN_PDJ_OUT_DIR:-/srv/scratch/${USER}/proteindj_output}}"
fi

OUT_DIR="${BASE_OUT_DIR}/${RUN_DIR}"
RESULTS_URL_BASE="${RESULTS_URL_BASE:-${PROTEINDESIGN_RESULTS_URL_BASE:-/pun/sys/dashboard/files/fs}}"

ln -s "$OUT_DIR" 2>/dev/null || true

export workflow="$WORKFLOW"
export run_dir="$RUN_DIR"
export user="${USER}"
export base_out_dir="${BASE_OUT_DIR}"
export results_url_base="${RESULTS_URL_BASE}"
export session_output_dir="$(pwd -P)"
