# Copy this file to `template/.env` and adjust values for your site.

# Open OnDemand / scheduler settings
OOD_CLUSTER=katana
OOD_QUEUE=submission
PROTEINDESIGN_NATIVE_DEFAULT=-A kod_proteindesign;-l select=1:ncpus=2:mem=4gb;-l walltime=48:00:00
OOD_EMAIL_DOMAIN=@ad.unsw.edu.au
# OOD_EMAIL=user@example.edu

# Shared result and preview settings
OOD_RESULTS_URL_BASE=/pun/sys/dashboard/files/fs
PROTEINDESIGN_MOLSTAR_URL_TEMPLATE=/pun/sys/dashboard/files/fs/__PATH_SEGMENTS__

# BindFlow settings
PROTEINDESIGN_BIND_BASEDIR=/srv/scratch/sbf-pipelines/bindflow/
PROTEINDESIGN_BIND_OUT_DIR=/srv/scratch/${USER}/bindflow_output
PROTEINDESIGN_BIND_WORK_DIR=/srv/scratch/${USER}/.bindflow/work
PROTEINDESIGN_BIND_REPOSITORY=Australian-Structural-Biology-Computing/bindflow
PROTEINDESIGN_BIND_REVISION=93e8ac776fae1c76d283dcc64f4e4571cae7a091
PROTEINDESIGN_BIND_NEXTFLOW_CONFIG=/srv/scratch/sbf-pipelines/bindflow/kod-bindflow.config

# ProteinDJ settings
PROTEINDESIGN_PDJ_BASEDIR=/srv/scratch/sbf-pipelines/pdj-denovo/
PROTEINDESIGN_PDJ_OUT_DIR=/srv/scratch/${USER}/proteindj_output
PROTEINDESIGN_PDJ_WORK_DIR=/srv/scratch/${USER}/.proteindj/work
PROTEINDESIGN_PDJ_REPOSITORY=tlitfin/proteindj
PROTEINDESIGN_PDJ_REVISION=main
PROTEINDESIGN_PDJ_NEXTFLOW_CONFIG=/srv/scratch/sbf-pipelines/pdj-denovo/kod-pdj-denovo.config
